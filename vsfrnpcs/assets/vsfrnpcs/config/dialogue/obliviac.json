      }
    },
    {
      code: "tooSoon",
      type: "talk",
      text: [ { value: "Ci trop tôt :-/" } ],
      jumpTo: "thx"
    },
    {
      code: "resetArchives",
      trigger: "resetDungeon",
      triggerData: {
        name: "resonancearchive"
      }
    },
    {
      code: "resetArchives",
      owner: "npc",
      trigger: "resetDungeon",
      triggerData: {
        x: "~5",
        z: "~7"
      }
    },
    {
      code: "thx",
      owner: "player",
      type: "talk",
      text: [ { value: "Merci Bobby!" } ]
    }
