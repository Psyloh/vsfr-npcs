        }
      ]
    },
    {
      code: "switchPrivileges",
      type: "jump",
      trigger: "switchPrivilege",
      triggerData: {
        values: {
          pri1: "block1",
          pri3: "block2",
          pri4: "block3",
          default : "privilegeDefault"
        }
      }
    },
    {
      code: "switchRole",
      type: "jump",
      trigger: "switchRole",
      triggerData: {
        values: {
          suvisitor: "roleNul",
          suplayer: "rolePasOuf",
          admin: "roleAdmin",
          default: "roleDefault"
        }
      }
    },
    {
      code: "roleNul",
      type: "talk",
      text: [ { value: "C'i d'la mèrde, j'i envi d'ti racketter..." } ],
      jumpTo: "thx"
    },
    {
      code: "rolePasOuf",
      type: "talk",
      text: [ { value: "Vas-y mé r'garde pas, sal péon!.." } ],
      jumpTo: "thx"
    },
    {
      code: "roleAdmin",
      type: "talk",
      text: [ { value: "Ouuuh, m'sieur le maître, ji m'incline! C'i pas mouah, j'i rien fé!" } ],
      jumpTo: "thx"
    },
    {
      code: "roleDefault",
      type: "talk",
      text: [ { value: "Ji sépa c'i kwa..." } ],
      jumpTo: "thx"
    },
    {
      code: "checkAdmin",
      type: "jump",
      trigger: "hasRole",
      triggerData: {
        role: "admin",
