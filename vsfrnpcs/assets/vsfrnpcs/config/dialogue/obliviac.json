        else: "notAdmin"
      }
    },
    {
      code: "yesAdmin",
      type: "talk",
      text: [ { value: "Wesh wallah t'i admin, toi!" } ],
      jumpTo: "thx"
    },
    {
      code: "notAdmin",
      type: "talk",
      text: [ { value: "Ti t'é cru-où? T'i pas admin, wesh..." } ],
      jumpTo: "thx"
    },
    {
      code: "checkRoot",
      type: "jump",
      trigger: "hasPrivilege",
      triggerData: {
        privilege: "root",
        if: "yesRoot",
        else: "notRoot"
      }
    },
    {
      code: "yesRoot",
      type: "talk",
      text: [ { value: "Wallamdalouloulalilallah ♪♫ T'i bien roôt!" } ],
      jumpTo: "thx"
    },
    {
      code: "notRoot",
      type: "talk",
      text: [ { value: "Ci li arabres qu'y'ont di routs... Toi, nan!" } ],
      jumpTo: "thx"
    },
    {
      code: "checkArchives",
      type: "jump",
      trigger: "canResetDungeon",
      triggerData: {
        name: "resonancearchive",
