                privileges: ["springevent", "summerevent", "automnevent", "winterevent" ],
                if: "playerseasonalevent",
                else: "playernoevent"
            }
        },
        {
			code: "playerseasonalevent",
			owner: "player",
			type: "talk",
			text: [
				{ value: "vsfrnpcs:dialogue-orario-jevil-seasonalevent", jumpTo: "checktypeseasonalevent"},
                { value: "vsfrnpcs:dialogue-player-sorrybye2", jumpTo: "close" },
			]
		},
        {
			code: "playercustomevent",
			owner: "player",
			type: "talk",
			text: [
